#!/usr/local/bin/python3

import argparse
import sys
import os
import subprocess
import requests
import time


CHAIN_RUNNING = "chain_running"
CHAIN_DIED = "chain_died"
CHAIN_FINISHED = "chain_finished"
CHAIN_STALLED = "chain_stalled"

def msg(out):
    print(out)

class Process:

    def __init__(self, name, cmd):
        self._p = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, universal_newlines=True)
        self.name = name

    def is_alive(self):
        return self._p.poll() is None

    def stop(self):
        print("stopping", self.name)
        self._p.terminate()

def start_vega_process(home, restore_from):
    cmd = ['vega', 'node']
    if home is not None:
        cmd.append("--home="+home)
    if restore_from is not None:
        cmd.append("--snapshot.load-from-block-height="+str(restore_from))
    print("starting Vega", cmd)
    return Process("vega", cmd)


def start_tm_process(home):
    cmd = ['vega', 'tm', 'node']
    if home is not None:
        cmd.append("--home="+home)
    print("starting Tendermint", cmd)
    return Process("tendermint", cmd)



def get_statistics(base_url):
    url = f"{base_url}/statistics"
    response = requests.get(url)
    if not response.ok:
        return None
    return response.json()["statistics"]
    




def is_running(vp, tp):

    if not tp.is_alive():
        print("tendermint died")
        return CHAIN_DIED

    if not vp.is_alive():
        print("vega died")
        return CHAIN_DIED


    stats =  get_statistics("http://localhost:3023")
    if stats is None:
        return CHAIN_DIED

    if stats["status"] == "CHAIN_STATUS_DISCONNECTED":
        print("chain running, currently at height", stats["blockHeight"])
        return CHAIN_RUNNING

    if stats["status"] == "CHAIN_STATUS_REPLAYING":
        return CHAIN_FINISHED


    return CHAIN_STALLED

def main():


    parser = argparse.ArgumentParser(description='Purge any state in the vegahome directory')
    parser.add_argument('--block', '-b', dest='block', required=True, type=int)
    args = parser.parse_args()

    vp = start_vega_process("/Users/wwestgarth/Downloads/archive/testnet/vega/node2", None)
    tp = start_tm_process("/Users/wwestgarth/Downloads/archive/testnet/tendermint/node2")

    print("Letting chain run...")
    try:

        # if things work, then statistics will change the chain status from disconnected -> replay
        # if things fail the tendermint processes should crash?
        # small pause so that the core node's endpoint is ready with statistics
        time.sleep(1)
        status = is_running(vp, tp)
        while status == CHAIN_RUNNING:
            time.sleep(1)
            status = is_running(vp, tp)

        if status == CHAIN_FINISHED:
            print("restore successful")
            return

        print("restore failed!")
    finally:
        tp.stop()
        vp.stop()

if __name__ == "__main__":
    main()